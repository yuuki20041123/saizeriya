  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "preview:pages": "wrangler pages dev .svelte-kit/cloudflare",
    "deploy:pages": "wrangler pages deploy .svelte-kit/cloudflare",
